FROM python:3.10-slim

# 1. Cài đặt các gói hệ thống cần thiết cho PyMuPDF và xử lý PDF
RUN apt-get update && apt-get install -y \
    build-essential \
    python3-dev \
    libmupdf-dev \
    swig \
    poppler-utils \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

# 2. Cài đặt các thư viện Python
COPY requirements.txt .
# Cài đặt pymupdf trước và cài bản cụ thể để tránh lỗi 'tools'
RUN pip install --no-cache-dir --upgrade pip && \
    pip install --no-cache-dir pymupdf==1.24.1 && \
    pip install --no-cache-dir -r requirements.txt && \
    pip install --no-cache-dir uvicorn accelerate bitsandbytes sentence-transformers

COPY . .

# 3. Chạy Server
CMD ["python", "mcp_server.py"]